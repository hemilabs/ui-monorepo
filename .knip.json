{
  "ignore": ["subgraphs/utils/index.ts"],
  "ignoreBinaries": ["ipconfig", "jq"],
  "ignoreDependencies": ["eslint-config-next", "eslint-config-prettier"],
  "workspaces": {
    "portal": {
      "typescript": {
        "config": ["tsconfig.json", "scripts/hemi-earn/tsconfig.json"]
      }
    },
    "portal-backend/api": {
      "entry": ["scripts/*.cjs"]
    },
    "subgraphs/*": {
      "entry": ["src/mappings/*.ts"]
    }
  }
}
