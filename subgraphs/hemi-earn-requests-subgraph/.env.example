# Required to use Envio HyperSync (the Ethereum / Agent side).
# Get a free token at https://envio.dev/app/api-tokens, then copy this file to
# `.env` and paste the token below.
ENVIO_API_TOKEN=

# Optional RPC override for Hemi (the Router side, which is indexed over RPC
# because HyperSync does not serve Hemi). Leave unset to use the public RPC
# hard-coded in config.yaml; set this and point config.yaml's Hemi `rpc.url`
# at it for a dedicated/paid endpoint.
HEMI_RPC_URL=
